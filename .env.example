# Copy to `.env.local` (or `.env`) for local dev. Vite loads these for server functions.
# On Vercel / Cloudflare, set the same names in the project dashboard (or wrangler secrets).

# On-chain stats (/stats/onchain) — Dune Analytics query API
# DUNE_API_KEY=

# Off-chain MCP tool-call stats (/stats/offchain) — Amplitude Export API
# AMPLITUDE_API_KEY=
# AMPLITUDE_SECRET_KEY=
# AMPLITUDE_REGION=us

# Amplitude export cache — Supabase (service role; server-only, never expose to the browser)
# CUSTOM_SUPABASE_URL=
# CUSTOM_SUPABASE_SERVICE_ROLE_KEY=
